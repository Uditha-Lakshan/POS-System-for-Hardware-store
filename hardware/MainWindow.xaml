<!-- MainWindow.xaml -->
<Window x:Class="HardwareShop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Hardware Shop Management System 2.0" Height="768" Width="1024" WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200"/>
            <!-- Sidebar -->
            <ColumnDefinition Width="*"/>
            <!-- Main Content -->
        </Grid.ColumnDefinitions>

        <!-- LEFT SIDEBAR (Teal Color from images) -->
        <Border Grid.Column="0" Background="#008F8F">
            <StackPanel Margin="0,50,0,0">
                <!-- Logo Area -->
                <Image Source="Assets/logo.png" Height="80" Margin="10"/>

                <!-- Navigation Buttons -->
                <Button Content="Items" Height="50" Background="Transparent" Foreground="White" FontSize="16" BorderThickness="0" Click="Nav_Items_Click"/>
                <Button Content="Categories" Height="50" Background="Transparent" Foreground="White" FontSize="16" BorderThickness="0" Click="Nav_Categories_Click"/>
                <Button Content="Customer" Height="50" Background="Transparent" Foreground="White" FontSize="16" BorderThickness="0" Click="Nav_Customer_Click"/>
                <Button Content="Billing" Height="50" Background="Transparent" Foreground="White" FontSize="16" BorderThickness="0" Click="Nav_Billing_Click"/>
                <Button Content="Dashboard" Height="50" Background="Transparent" Foreground="White" FontSize="16" BorderThickness="0" Click="Nav_Dashboard_Click"/>

                <Button Content="LOGOUT" Background="#E6005C" Foreground="White" Height="40" Margin="10,50,10,10" FontWeight="Bold" Click="BtnLogout_Click"/>
            </StackPanel>
        </Border>

        <!-- RIGHT CONTENT AREA -->
        <Grid Grid.Column="1" Background="White">
            <Grid.RowDefinitions>
                <RowDefinition Height="40"/>
                <!-- Header -->
                <RowDefinition Height="*"/>
                <!-- Active Page -->
            </Grid.RowDefinitions>

            <!-- Top Header -->
            <Border Grid.Row="0" Background="#008F8F">
                <TextBlock Text="Hardware Shop Management System 2.0" Foreground="White" FontSize="18" VerticalAlignment="Center" Margin="20,0,0,0"/>
            </Border>

            <!-- Pages will load inside this frame -->
            <Frame x:Name="MainFrame" Grid.Row="1" NavigationUIVisibility="Hidden"/>
        </Grid>
    </Grid>
</Window>