<Page x:Class="HardwareShop.Pages.DashboardPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="DashboardPage" Loaded="Page_Loaded">
    <Grid Margin="20">
        <StackPanel>
            <TextBlock Text="Store Dashboard" FontSize="22" FontWeight="Bold" Foreground="#008F8F" Margin="0,0,0,20"/>

            <UniformGrid Columns="2" Rows="2" VerticalAlignment="Top">
                <!-- Total Items -->
                <Border Background="#FF9900" Margin="10" Padding="20" CornerRadius="10">
                    <StackPanel>
                        <TextBlock Text="Total Inventory Items" Foreground="White" FontSize="16"/>
                        <TextBlock x:Name="txtTotalItems" Text="0" Foreground="White" FontSize="36" FontWeight="Bold"/>
                    </StackPanel>
                </Border>

                <!-- Total Customers -->
                <Border Background="#006666" Margin="10" Padding="20" CornerRadius="10">
                    <StackPanel>
                        <TextBlock Text="Total Customers" Foreground="White" FontSize="16"/>
                        <TextBlock x:Name="txtTotalCustomers" Text="0" Foreground="White" FontSize="36" FontWeight="Bold"/>
                    </StackPanel>
                </Border>

                <!-- Outstanding Debt -->
                <Border Background="#E6005C" Margin="10" Padding="20" CornerRadius="10">
                    <StackPanel>
                        <TextBlock Text="Outstanding Debt Owed" Foreground="White" FontSize="16"/>
                        <TextBlock x:Name="txtTotalDebt" Text="$0.00" Foreground="White" FontSize="36" FontWeight="Bold"/>
                    </StackPanel>
                </Border>
            </UniformGrid>
        </StackPanel>
    </Grid>
</Page>