<Page x:Class="HardwareShop.Pages.DashboardPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="DashboardPage" Loaded="Page_Loaded">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="1.2*"/>
            <RowDefinition Height="1*"/>
        </Grid.RowDefinitions>

        <!-- Page Header -->
        <DockPanel Grid.Row="0" Margin="0,0,0,12">
            <TextBlock Text="📊 Executive Dashboard &amp; Revenue Analytics - Nimal Hardware Store" FontSize="18" FontWeight="Bold" Foreground="#0F172A"/>
            <Button Content="🔄 Refresh Analytics" HorizontalAlignment="Right" Background="#0D9488" Foreground="White" FontWeight="Bold" Padding="14,6" Click="BtnRefresh_Click" Cursor="Hand"/>
        </DockPanel>

        <!-- Stat Cards Uniform Grid -->
        <UniformGrid Grid.Row="1" Columns="4" Margin="0,0,0,12">
            <!-- Today's Revenue -->
            <Border Background="#059669" Margin="4" Padding="14" CornerRadius="8">
                <StackPanel>
                    <TextBlock Text="💰 Today's Revenue" Foreground="#ECFDF5" FontSize="11" FontWeight="SemiBold"/>
                    <TextBlock x:Name="txtTodaySales" Text="Rs. 0.00" Foreground="White" FontSize="24" FontWeight="Bold" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>

            <!-- Total Inventory Items -->
            <Border Background="#D97706" Margin="4" Padding="14" CornerRadius="8">
                <StackPanel>
                    <TextBlock Text="📦 Total Stock Qty" Foreground="#FFFBEB" FontSize="11" FontWeight="SemiBold"/>
                    <TextBlock x:Name="txtTotalItems" Text="0" Foreground="White" FontSize="24" FontWeight="Bold" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>

            <!-- Total Customers -->
            <Border Background="#0D9488" Margin="4" Padding="14" CornerRadius="8">
                <StackPanel>
                    <TextBlock Text="👥 Registered Customers" Foreground="#CCFBF1" FontSize="11" FontWeight="SemiBold"/>
                    <TextBlock x:Name="txtTotalCustomers" Text="0" Foreground="White" FontSize="24" FontWeight="Bold" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>

            <!-- Outstanding Debt -->
            <Border Background="#DC2626" Margin="4" Padding="14" CornerRadius="8">
                <StackPanel>
                    <TextBlock Text="⚠️ Outstanding Customer Debt" Foreground="#FEF2F2" FontSize="11" FontWeight="SemiBold"/>
                    <TextBlock x:Name="txtTotalDebt" Text="Rs. 0.00" Foreground="White" FontSize="24" FontWeight="Bold" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>
        </UniformGrid>

        <!-- MIDDLE ROW: REVENUE ANALYSIS CHART SHOWCASE (LAST 7 DAYS REVENUE BAR CHART) -->
        <Border Grid.Row="2" Background="White" CornerRadius="8" Padding="15" Margin="0,0,0,12">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <DockPanel Grid.Row="0" Margin="0,0,0,10">
                    <TextBlock Text="📈 7-Day Sales &amp; Revenue Trends (Rs.)" FontSize="14" FontWeight="Bold" Foreground="#0F172A"/>
                    <TextBlock x:Name="lbl7DayTotal" Text="Total 7-Day Sales: Rs. 0.00" HorizontalAlignment="Right" Foreground="#0D9488" FontWeight="Bold" FontSize="12"/>
                </DockPanel>

                <!-- Custom WPF Revenue Bar Chart Canvas & Labels Container -->
                <Grid Grid.Row="1">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Canvas x:Name="canvasChart" Grid.Row="0" Background="#F8FAFC" ClipToBounds="True" SizeChanged="CanvasChart_SizeChanged"/>

                    <!-- X-Axis Labels Container -->
                    <UniformGrid x:Name="gridChartLabels" Grid.Row="1" Columns="7" Margin="0,4,0,0"/>
                </Grid>
            </Grid>
        </Border>

        <!-- BOTTOM ROW: DUAL ALERT TABLES: LOW STOCK (<= 10 Pcs) & ACTIVE DEBTORS -->
        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="5*"/>
                <ColumnDefinition Width="5*"/>
            </Grid.ColumnDefinitions>

            <!-- Left Panel: Low Stock Alert (<= 10 Pcs) -->
            <Border Grid.Column="0" Background="White" CornerRadius="8" Padding="12" Margin="0,0,6,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="⚠️ Low Stock Alert (Items ≤ 10 Pcs)" FontSize="13" FontWeight="Bold" Foreground="#DC2626" Margin="0,0,0,8"/>

                    <DataGrid x:Name="dgLowStock" Grid.Row="1" AutoGenerateColumns="False" IsReadOnly="True" GridLinesVisibility="Horizontal" HeadersVisibility="Column">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Code" Binding="{Binding ItCode}" Width="45"/>
                            <DataGridTextColumn Header="Item Name" Binding="{Binding ItName}" Width="*"/>
                            <DataGridTextColumn Header="Price" Binding="{Binding ItPrice, StringFormat='Rs. {0:F2}'}" Width="80"/>
                            <DataGridTextColumn Header="Stock" Binding="{Binding ItStock}" Foreground="#DC2626" FontWeight="Bold" Width="60"/>
                            <DataGridTextColumn Header="Unit" Binding="{Binding Unit}" Width="50"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <!-- Right Panel: Active Debtors Alert -->
            <Border Grid.Column="1" Background="White" CornerRadius="8" Padding="12" Margin="6,0,0,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="💳 Active Debtors Accounts (Debt > Rs. 0.00)" FontSize="13" FontWeight="Bold" Foreground="#0F172A" Margin="0,0,0,8"/>

                    <DataGrid x:Name="dgDebtors" Grid.Row="1" AutoGenerateColumns="False" IsReadOnly="True" GridLinesVisibility="Horizontal" HeadersVisibility="Column">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="40"/>
                            <DataGridTextColumn Header="Customer Name" Binding="{Binding Name}" Width="*"/>
                            <DataGridTextColumn Header="Phone" Binding="{Binding Phone}" Width="95"/>
                            <DataGridTextColumn Header="Debt Balance" Binding="{Binding CurrentDebt, StringFormat='Rs. {0:F2}'}" Foreground="#DC2626" FontWeight="Bold" Width="105"/>
                            <DataGridTextColumn Header="Avail Credit" Binding="{Binding AvailableCredit, StringFormat='Rs. {0:F2}'}" Foreground="#059669" FontWeight="Bold" Width="105"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Page>