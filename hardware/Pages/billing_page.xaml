<Page x:Class="HardwareShop.Pages.BillingPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="BillingPage" Loaded="Page_Loaded">

    <Grid Margin="15">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="6*"/>
            <!-- Left Side: Inventory Search & Selection -->
            <ColumnDefinition Width="4*"/>
            <!-- Right Side: Cart & Checkout -->
        </Grid.ColumnDefinitions>

        <!-- LEFT PANEL: INVENTORY & ITEM SELECTION -->
        <Border Grid.Column="0" Background="White" CornerRadius="8" Padding="15" Margin="0,0,10,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Search & Category Filters -->
                <Grid Grid.Row="0" Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="140"/>
                        <ColumnDefinition Width="140"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Margin="0,0,8,0">
                        <TextBlock Text="🔍 Search Inventory (Name, Code or Sub-Cat)" Foreground="#64748B" FontSize="11" FontWeight="SemiBold"/>
                        <TextBox x:Name="txtSearchInventory" Height="30" VerticalContentAlignment="Center" TextChanged="TxtSearchInventory_TextChanged"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Margin="0,0,8,0">
                        <TextBlock Text="Main Category" Foreground="#64748B" FontSize="11" FontWeight="SemiBold"/>
                        <ComboBox x:Name="cmbFilterCategory" Height="30" DisplayMemberPath="CatName" SelectedValuePath="CatCode" SelectionChanged="CmbFilterCategory_SelectionChanged"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Sub-Category" Foreground="#0D9488" FontSize="11" FontWeight="SemiBold"/>
                        <ComboBox x:Name="cmbFilterSubCategory" Height="30" DisplayMemberPath="SubCatName" SelectedValuePath="SubCatCode" SelectionChanged="CmbFilterSubCategory_SelectionChanged"/>
                    </StackPanel>
                </Grid>

                <!-- Item Add Controls Bar -->
                <Border Grid.Row="1" Background="#F1F5F9" CornerRadius="6" Padding="10" Margin="0,0,0,12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="1*"/>
                            <ColumnDefinition Width="1*"/>
                            <ColumnDefinition Width="1.2*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Margin="0,0,8,0">
                            <TextBlock Text="Selected Item" Foreground="#334155" FontSize="11" FontWeight="Bold"/>
                            <TextBox x:Name="txtItemSearch" Height="30" IsReadOnly="True" Background="#E2E8F0" VerticalContentAlignment="Center"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Margin="0,0,8,0">
                            <TextBlock Text="Price (Rs.)" Foreground="#334155" FontSize="11" FontWeight="Bold"/>
                            <TextBox x:Name="txtPrice" Height="30" VerticalContentAlignment="Center"/>
                        </StackPanel>

                        <StackPanel Grid.Column="2" Margin="0,0,8,0">
                            <TextBlock Text="Qty" Foreground="#334155" FontSize="11" FontWeight="Bold"/>
                            <TextBox x:Name="txtQty" Height="30" Text="1" VerticalContentAlignment="Center"/>
                        </StackPanel>

                        <StackPanel Grid.Column="3" Margin="0,0,8,0">
                            <TextBlock Text="Item Disc (Rs.)" Foreground="#EF4444" FontSize="11" FontWeight="Bold"/>
                            <TextBox x:Name="txtDiscount" Height="30" Text="0" VerticalContentAlignment="Center"/>
                        </StackPanel>

                        <Button Grid.Column="4" Content="➕ Add to Cart" Background="#0D9488" Foreground="White" FontWeight="Bold" Width="110" Height="30" VerticalAlignment="Bottom" Click="BtnAddToBill_Click" Cursor="Hand"/>
                    </Grid>
                </Border>

                <!-- Inventory DataGrid -->
                <DataGrid x:Name="dgInventory" Grid.Row="2" AutoGenerateColumns="False" IsReadOnly="True" SelectionMode="Single" SelectionChanged="DgInventory_SelectionChanged" GridLinesVisibility="Horizontal" HeadersVisibility="Column">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Code" Binding="{Binding ItCode}" Width="50"/>
                        <DataGridTextColumn Header="Item Name" Binding="{Binding ItName}" Width="1.8*"/>
                        <DataGridTextColumn Header="Category" Binding="{Binding Category.CatName}" Width="1.1*"/>
                        <DataGridTextColumn Header="Sub-Cat" Binding="{Binding SubCategory.SubCatName}" Foreground="#0D9488" Width="1.1*"/>
                        <DataGridTextColumn Header="Price" Binding="{Binding ItPrice, StringFormat='Rs. {0:F2}'}" Width="80"/>
                        <DataGridTextColumn Header="Stock" Binding="{Binding ItStock}" Width="50"/>
                        <DataGridTextColumn Header="Unit" Binding="{Binding Unit}" Width="50"/>
                        <DataGridTextColumn Header="Max Disc." Binding="{Binding MaxItemDiscount, StringFormat='Rs. {0:F2}'}" Foreground="#EF4444" Width="75"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>

        <!-- RIGHT PANEL: CART & CHECKOUT -->
        <Border Grid.Column="1" Background="White" CornerRadius="8" Padding="15" Margin="10,0,0,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <DockPanel Grid.Row="0" Margin="0,0,0,10">
                    <TextBlock Text="🛒 Shopping Cart" FontSize="16" FontWeight="Bold" Foreground="#0F172A"/>
                    <Button Content="Clear Cart" HorizontalAlignment="Right" Background="#64748B" Foreground="White" Padding="8,3" Click="BtnClearCart_Click" Cursor="Hand"/>
                </DockPanel>

                <!-- Cart DataGrid -->
                <DataGrid x:Name="dgClientBill" Grid.Row="1" AutoGenerateColumns="False" IsReadOnly="True" GridLinesVisibility="Horizontal" HeadersVisibility="Column">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Item" Binding="{Binding ItemName}" Width="*"/>
                        <DataGridTextColumn Header="Price" Binding="{Binding Price, StringFormat='Rs. {0:F2}'}" Width="75"/>
                        <DataGridTextColumn Header="Qty" Binding="{Binding Qty}" Width="40"/>
                        <DataGridTextColumn Header="Disc." Binding="{Binding AppliedDiscount, StringFormat='Rs. {0:F2}'}" Foreground="#EF4444" Width="70"/>
                        <DataGridTextColumn Header="Total" Binding="{Binding Total, StringFormat='Rs. {0:F2}'}" Width="75"/>
                        <DataGridTemplateColumn Width="35">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Content="❌" Background="Transparent" BorderThickness="0" Foreground="#EF4444" FontWeight="Bold" Click="BtnRemoveCartItem_Click" ToolTip="Remove Item"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>

                <!-- Cart Total & Payment Box -->
                <StackPanel Grid.Row="2" Margin="0,12,0,0">
                    <!-- Customer Selection for Loyalty Discount & Debt -->
                    <Border Background="#F8FAFC" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="6" Padding="10" Margin="0,0,0,10">
                        <StackPanel>
                            <TextBlock Text="👤 Customer Account &amp; Loyalty Discount:" FontSize="11" FontWeight="Bold" Foreground="#334155" Margin="0,0,0,3"/>
                            <ComboBox x:Name="cmbCustomers" DisplayMemberPath="Name" SelectedValuePath="Id" Height="28" SelectionChanged="CmbCustomers_SelectionChanged"/>

                            <!-- Live Customer Debt & Credit Badge -->
                            <Grid x:Name="panelCustomerCreditInfo" Visibility="Collapsed" Margin="0,8,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="0" Background="#FEF2F2" BorderBrush="#FCA5A5" BorderThickness="1" CornerRadius="4" Padding="6,4" Margin="0,0,4,0">
                                    <StackPanel>
                                        <TextBlock Text="Debt" FontSize="10" Foreground="#991B1B"/>
                                        <TextBlock x:Name="txtCustCurrentDebt" Text="Rs. 0.00" FontSize="12" FontWeight="Bold" Foreground="#DC2626"/>
                                    </StackPanel>
                                </Border>

                                <Border Grid.Column="1" Background="#F1F5F9" BorderBrush="#CBD5E1" BorderThickness="1" CornerRadius="4" Padding="6,4" Margin="2,0,2,0">
                                    <StackPanel>
                                        <TextBlock Text="Credit Limit" FontSize="10" Foreground="#475569"/>
                                        <TextBlock x:Name="txtCustCreditLimit" Text="Rs. 0.00" FontSize="12" FontWeight="Bold" Foreground="#334155"/>
                                    </StackPanel>
                                </Border>

                                <Border Grid.Column="2" Background="#ECFDF5" BorderBrush="#6EE7B7" BorderThickness="1" CornerRadius="4" Padding="6,4" Margin="4,0,0,0">
                                    <StackPanel>
                                        <TextBlock Text="Avail Credit" FontSize="10" Foreground="#065F46"/>
                                        <TextBlock x:Name="txtCustAvailableCredit" Text="Rs. 0.00" FontSize="12" FontWeight="Bold" Foreground="#059669"/>
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- Total Summary Card -->
                    <Border Background="#F0FDF4" BorderBrush="#BBF7D0" BorderThickness="1" CornerRadius="6" Padding="10" Margin="0,0,0,10">
                        <StackPanel>
                            <DockPanel Margin="0,2">
                                <TextBlock Text="Cart Subtotal:" Foreground="#334155"/>
                                <TextBlock x:Name="txtSubTotal" Text="Rs. 0.00" HorizontalAlignment="Right" FontWeight="SemiBold"/>
                            </DockPanel>

                            <DockPanel Margin="0,2">
                                <TextBlock Text="Item Discounts:" Foreground="#EF4444"/>
                                <TextBlock x:Name="txtItemDiscountTotal" Text="-Rs. 0.00" HorizontalAlignment="Right" Foreground="#EF4444" FontWeight="SemiBold"/>
                            </DockPanel>

                            <DockPanel Margin="0,2">
                                <TextBlock x:Name="lblLoyaltyDiscountTitle" Text="Customer Loyalty Disc:" Foreground="#059669"/>
                                <TextBlock x:Name="txtLoyaltyDiscountTotal" Text="-Rs. 0.00" HorizontalAlignment="Right" Foreground="#059669" FontWeight="SemiBold"/>
                            </DockPanel>

                            <Separator Margin="0,4"/>
                            <DockPanel>
                                <TextBlock Text="Grand Total:" FontSize="16" FontWeight="Bold" Foreground="#0F172A"/>
                                <TextBlock x:Name="txtTotal" Text="Rs. 0.00" FontSize="20" FontWeight="Bold" Foreground="#0D9488" HorizontalAlignment="Right"/>
                            </DockPanel>
                        </StackPanel>
                    </Border>

                    <!-- Payment Mode Selection -->
                    <TextBlock Text="Payment Method:" FontWeight="Bold" Margin="0,0,0,5" Foreground="#0F172A"/>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <RadioButton x:Name="rbCash" Content="💵 Cash" IsChecked="True" Margin="0,0,15,0" Checked="PaymentMode_Changed"/>
                        <RadioButton x:Name="rbCard" Content="💳 Card" Margin="0,0,15,0" Checked="PaymentMode_Changed"/>
                        <RadioButton x:Name="rbDebt" Content="👤 Customer Credit" Checked="PaymentMode_Changed"/>
                    </StackPanel>

                    <!-- Cash Payment Inputs -->
                    <Grid x:Name="panelCash" Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Margin="0,0,5,0">
                            <TextBlock Text="Cash Received (Rs.):" FontSize="11" Foreground="#475569"/>
                            <TextBox x:Name="txtCashReceived" Height="28" VerticalContentAlignment="Center" TextChanged="TxtCashReceived_TextChanged"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Margin="5,0,0,0">
                            <TextBlock Text="Change Return (Rs.):" FontSize="11" Foreground="#475569"/>
                            <TextBox x:Name="txtChangeReturn" Height="28" IsReadOnly="True" Background="#F1F5F9" FontWeight="Bold" Foreground="#0D9488" VerticalContentAlignment="Center"/>
                        </StackPanel>
                    </Grid>

                    <!-- Customer Debt Warning Panel -->
                    <TextBlock x:Name="txtDebtNote" Text="* Transaction amount will be added to customer debt account." Visibility="Collapsed" FontSize="11" Foreground="#D97706" Margin="0,0,0,8"/>

                    <!-- Checkout Button -->
                    <Button Content="⚡ Complete Checkout &amp; Print Receipt" Background="#0D9488" Foreground="White" Height="42" FontSize="14" FontWeight="Bold" Click="BtnCheckout_Click" Cursor="Hand"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Page>