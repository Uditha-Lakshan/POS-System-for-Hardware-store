<Page x:Class="HardwareShop.Pages.BillingPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="BillingPage">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- TOP INPUTS -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,20">
            <StackPanel Margin="0,0,15,0">
                <TextBlock Text="Item" Foreground="Gray"/>
                <TextBox x:Name="txtItemSearch" Width="150" Height="25"/>
            </StackPanel>

            <StackPanel Margin="0,0,15,0">
                <TextBlock Text="Quantity" Foreground="Gray"/>
                <TextBox x:Name="txtQty" Width="80" Height="25"/>
            </StackPanel>

            <!-- THIS IS THE NEW PRICE BOX THAT WAS MISSING -->
            <StackPanel Margin="0,0,15,0">
                <TextBlock Text="Price" Foreground="Gray"/>
                <TextBox x:Name="txtPrice" Width="80" Height="25"/>
            </StackPanel>

            <StackPanel Margin="0,0,15,0">
                <TextBlock Text="Discount ($)" Foreground="Red"/>
                <TextBox x:Name="txtDiscount" Width="80" Height="25" Text="0"/>
            </StackPanel>

            <Button Content="Add To Bill" Background="#FF9900" Foreground="White" Width="100" Height="30" Margin="10,15,0,0" Click="BtnAddToBill_Click"/>
        </StackPanel>

        <!-- DATA GRIDS -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="6*"/>
                <ColumnDefinition Width="4*"/>
            </Grid.ColumnDefinitions>

            <!-- Inventory List -->
            <DataGrid x:Name="dgInventory" Grid.Column="0" AutoGenerateColumns="True" Margin="0,0,10,0"/>

            <!-- Client Bill -->
            <StackPanel Grid.Column="1">
                <DataGrid x:Name="dgClientBill" AutoGenerateColumns="True" Height="300"/>
                <TextBlock x:Name="txtTotal" Text="Total: $0.00" FontSize="20" FontWeight="Bold" Margin="0,10,0,0"/>

                <TextBlock Text="Charge to Customer Account (Debt):" Margin="0,10,0,5"/>
                <ComboBox x:Name="cmbCustomers" DisplayMemberPath="Name" SelectedValuePath="CustomerId" Height="25"/>

                <Button Content="Checkout / Print Bill" Background="#008F8F" Foreground="White" Height="40" Margin="0,10,0,0" Click="BtnCheckout_Click"/>
            </StackPanel>
        </Grid>
    </Grid>
</Page>