<Page x:Class="HardwareShop.Pages.ItemsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="ItemsPage">
    <Grid Margin="20">
        <StackPanel>
            <TextBlock Text="Items Management" FontSize="18" Foreground="#E6005C" Margin="0,0,0,10"/>

            <WrapPanel Margin="0,0,0,20">
                <StackPanel Margin="0,0,15,10">
                    <TextBlock Text="Item Name" Foreground="Gray"/>
                    <TextBox x:Name="txtItemName" Width="150" Height="25"/>
                </StackPanel>
                <StackPanel Margin="0,0,15,10">
                    <TextBlock Text="Category" Foreground="Gray"/>
                    <ComboBox x:Name="cmbCategory" Width="150" Height="25" DisplayMemberPath="CatName" SelectedValuePath="CatCode"/>
                </StackPanel>
                <StackPanel Margin="0,0,15,10">
                    <TextBlock Text="Price" Foreground="Gray"/>
                    <TextBox x:Name="txtPrice" Width="80" Height="25"/>
                </StackPanel>
                <StackPanel Margin="0,0,15,10">
                    <TextBlock Text="Stock Quantity" Foreground="Gray"/>
                    <TextBox x:Name="txtStock" Width="80" Height="25"/>
                </StackPanel>
                <StackPanel Margin="0,0,15,10">
                    <TextBlock Text="Manufacturer" Foreground="Gray"/>
                    <TextBox x:Name="txtManufacturer" Width="120" Height="25"/>
                </StackPanel>
                <StackPanel Margin="0,0,15,10">
                    <TextBlock Text="Max Discount ($)" Foreground="Gray"/>
                    <TextBox x:Name="txtMaxDiscount" Width="90" Height="25" Text="0"/>
                </StackPanel>
            </WrapPanel>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,20">
                <Button Content="Edit" Background="#008F8F" Foreground="White" Width="100" Height="30" Margin="0,0,15,0" Click="BtnEdit_Click"/>
                <Button Content="Add Item" Background="#006666" Foreground="White" Width="120" Height="30" Margin="0,0,15,0" Click="BtnAdd_Click"/>
                <Button Content="Delete" Background="#E6005C" Foreground="White" Width="100" Height="30" Click="BtnDelete_Click"/>
            </StackPanel>

            <DataGrid x:Name="dgItems" AutoGenerateColumns="True" Height="250" SelectionChanged="DgItems_SelectionChanged"/>
        </StackPanel>
    </Grid>
</Page>