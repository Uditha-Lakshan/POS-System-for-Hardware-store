<Page x:Class="HardwareShop.Pages.ItemsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="ItemsPage">
    <Grid Margin="15">
        <Border Background="White" CornerRadius="8" Padding="20">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Header -->
                <DockPanel Grid.Row="0" Margin="0,0,0,15">
                    <TextBlock Text="📦 Hardware Inventory &amp; Stock Control" FontSize="18" FontWeight="Bold" Foreground="#0F172A"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <TextBlock Text="🔍 Filter Items:" VerticalAlignment="Center" Margin="0,0,8,0" Foreground="#64748B"/>
                        <TextBox x:Name="txtSearch" Width="220" Height="30" VerticalContentAlignment="Center" TextChanged="TxtSearch_TextChanged"/>
                    </StackPanel>
                </DockPanel>

                <!-- Inputs Form -->
                <Border Grid.Row="1" Background="#F8FAFC" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="6" Padding="15" Margin="0,0,0,15">
                    <WrapPanel Margin="0,0,0,5">
                        <StackPanel Margin="0,0,15,10">
                            <TextBlock Text="Item Name" Foreground="#334155" FontWeight="SemiBold" FontSize="11"/>
                            <TextBox x:Name="txtItemName" Width="180" Height="30" VerticalContentAlignment="Center"/>
                        </StackPanel>

                        <StackPanel Margin="0,0,15,10">
                            <TextBlock Text="Category" Foreground="#334155" FontWeight="SemiBold" FontSize="11"/>
                            <ComboBox x:Name="cmbCategory" Width="140" Height="30" DisplayMemberPath="CatName" SelectedValuePath="CatCode" SelectionChanged="CmbCategory_SelectionChanged"/>
                        </StackPanel>

                        <StackPanel Margin="0,0,15,10">
                            <TextBlock Text="Sub-Category" Foreground="#0D9488" FontWeight="SemiBold" FontSize="11"/>
                            <ComboBox x:Name="cmbSubCategory" Width="140" Height="30" DisplayMemberPath="SubCatName" SelectedValuePath="SubCatCode"/>
                        </StackPanel>

                        <StackPanel Margin="0,0,15,10">
                            <TextBlock Text="Unit Price (Rs.)" Foreground="#334155" FontWeight="SemiBold" FontSize="11"/>
                            <TextBox x:Name="txtPrice" Width="90" Height="30" VerticalContentAlignment="Center"/>
                        </StackPanel>

                        <StackPanel Margin="0,0,15,10">
                            <TextBlock Text="Stock Qty" Foreground="#334155" FontWeight="SemiBold" FontSize="11"/>
                            <TextBox x:Name="txtStock" Width="80" Height="30" VerticalContentAlignment="Center"/>
                        </StackPanel>

                        <StackPanel Margin="0,0,15,10">
                            <TextBlock Text="Unit of Measure" Foreground="#334155" FontWeight="SemiBold" FontSize="11"/>
                            <ComboBox x:Name="cmbUnit" Width="90" Height="30" SelectedIndex="0">
                                <ComboBoxItem Content="Pcs"/>
                                <ComboBoxItem Content="Kg"/>
                                <ComboBoxItem Content="Meters"/>
                                <ComboBoxItem Content="Liters"/>
                                <ComboBoxItem Content="Boxes"/>
                                <ComboBoxItem Content="Packs"/>
                            </ComboBox>
                        </StackPanel>

                        <StackPanel Margin="0,0,15,10">
                            <TextBlock Text="Manufacturer" Foreground="#334155" FontWeight="SemiBold" FontSize="11"/>
                            <TextBox x:Name="txtManufacturer" Width="130" Height="30" VerticalContentAlignment="Center"/>
                        </StackPanel>

                        <StackPanel Margin="0,0,15,10">
                            <TextBlock Text="Max Discount (Rs.)" Foreground="#EF4444" FontWeight="SemiBold" FontSize="11"/>
                            <TextBox x:Name="txtMaxDiscount" Width="100" Height="30" Text="0" VerticalContentAlignment="Center"/>
                        </StackPanel>
                    </WrapPanel>
                </Border>

                <!-- Action Buttons -->
                <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,0,15">
                    <Button Content="✨ Clear Form" Background="#64748B" Foreground="White" Width="105" Height="34" Margin="0,0,10,0" Click="BtnClear_Click" Cursor="Hand"/>
                    <Button Content="➕ Add Item" Background="#0D9488" Foreground="White" FontWeight="Bold" Width="115" Height="34" Margin="0,0,10,0" Click="BtnAdd_Click" Cursor="Hand"/>
                    <Button Content="✏️ Edit Selected" Background="#0284C7" Foreground="White" FontWeight="Bold" Width="125" Height="34" Margin="0,0,10,0" Click="BtnEdit_Click" Cursor="Hand"/>
                    <Button Content="🗑️ Delete Item" Background="#EF4444" Foreground="White" FontWeight="Bold" Width="115" Height="34" Click="BtnDelete_Click" Cursor="Hand"/>
                </StackPanel>

                <!-- DataGrid -->
                <DataGrid x:Name="dgItems" Grid.Row="3" AutoGenerateColumns="False" IsReadOnly="True" SelectionMode="Single" SelectionChanged="DgItems_SelectionChanged" GridLinesVisibility="Horizontal" HeadersVisibility="Column">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Code" Binding="{Binding ItCode}" Width="55"/>
                        <DataGridTextColumn Header="Item Name" Binding="{Binding ItName}" Width="1.8*"/>
                        <DataGridTextColumn Header="Category" Binding="{Binding Category.CatName}" Width="1.2*"/>
                        <DataGridTextColumn Header="Sub-Category" Binding="{Binding SubCategory.SubCatName}" Foreground="#0D9488" Width="1.2*"/>
                        <DataGridTextColumn Header="Price (Rs.)" Binding="{Binding ItPrice, StringFormat='Rs. {0:F2}'}" Width="100"/>
                        <DataGridTextColumn Header="Stock" Binding="{Binding ItStock}" Width="65"/>
                        <DataGridTextColumn Header="Unit" Binding="{Binding Unit}" Width="60"/>
                        <DataGridTextColumn Header="Manufacturer" Binding="{Binding Manufacturer}" Width="1.2*"/>
                        <DataGridTextColumn Header="Max Disc (Rs.)" Binding="{Binding MaxItemDiscount, StringFormat='Rs. {0:F2}'}" Foreground="#EF4444" Width="95"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>
    </Grid>
</Page>