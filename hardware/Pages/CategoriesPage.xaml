<Page x:Class="HardwareShop.Pages.CategoriesPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="CategoriesPage">
    <Grid Margin="20">
        <StackPanel>
            <TextBlock Text="Categories Management" FontSize="18" Foreground="#E6005C" Margin="0,0,0,20"/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,20">
                <StackPanel Margin="0,0,20,0">
                    <TextBlock Text="Category Name" Foreground="Gray"/>
                    <TextBox x:Name="txtCatName" Width="200" Height="25"/>
                </StackPanel>
                <StackPanel>
                    <TextBlock Text="Category Discount (%)" Foreground="Gray"/>
                    <TextBox x:Name="txtCatDiscount" Width="150" Height="25" Text="0"/>
                </StackPanel>
            </StackPanel>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,20">
                <Button Content="Edit" Background="#008F8F" Foreground="White" Width="100" Height="30" Margin="0,0,15,0" Click="BtnEdit_Click"/>
                <Button Content="Add Category" Background="#006666" Foreground="White" Width="120" Height="30" Margin="0,0,15,0" Click="BtnAdd_Click"/>
                <Button Content="Delete" Background="#E6005C" Foreground="White" Width="100" Height="30" Click="BtnDelete_Click"/>
            </StackPanel>

            <TextBlock Text="Categories List" HorizontalAlignment="Center" Margin="0,0,0,10" Foreground="Gray"/>
            <DataGrid x:Name="dgCategories" AutoGenerateColumns="False" Height="300" SelectionChanged="DgCategories_SelectionChanged">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Code" Binding="{Binding CatCode}" Width="*"/>
                    <DataGridTextColumn Header="Category Name" Binding="{Binding CatName}" Width="3*"/>
                    <DataGridTextColumn Header="Discount %" Binding="{Binding CategoryDiscountPercentage}" Width="*"/>
                </DataGrid.Columns>
            </DataGrid>
        </StackPanel>
    </Grid>
</Page>