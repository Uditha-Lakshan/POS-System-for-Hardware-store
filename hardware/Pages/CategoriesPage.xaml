<Page x:Class="HardwareShop.Pages.CategoriesPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="CategoriesPage">
    <Grid Margin="15">
        <Border Background="White" CornerRadius="8" Padding="20">
            <TabControl x:Name="tabControlCategory" Background="Transparent" BorderThickness="0">
                <!-- TAB 1: MAIN CATEGORIES -->
                <TabItem Header="🏷️ Main Categories" FontSize="14" FontWeight="Bold">
                    <Grid Margin="0,15,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Header & Search -->
                        <DockPanel Grid.Row="0" Margin="0,0,0,15">
                            <TextBlock Text="Main Categories Management" FontSize="16" FontWeight="Bold" Foreground="#0F172A"/>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <TextBlock Text="🔍 Filter Categories:" VerticalAlignment="Center" Margin="0,0,8,0" Foreground="#64748B" FontSize="12"/>
                                <TextBox x:Name="txtSearchCategory" Width="200" Height="28" VerticalContentAlignment="Center" TextChanged="TxtSearchCategory_TextChanged"/>
                            </StackPanel>
                        </DockPanel>

                        <!-- Main Category Inputs -->
                        <Border Grid.Row="1" Background="#F8FAFC" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="6" Padding="12" Margin="0,0,0,12">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="1.5*"/>
                                    <ColumnDefinition Width="2*"/>
                                    <ColumnDefinition Width="1*"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0" Margin="0,0,12,0">
                                    <TextBlock Text="Category Name" Foreground="#334155" FontSize="11" FontWeight="Bold"/>
                                    <TextBox x:Name="txtCatName" Height="28" VerticalContentAlignment="Center"/>
                                </StackPanel>

                                <StackPanel Grid.Column="1" Margin="0,0,12,0">
                                    <TextBlock Text="Description / Notes" Foreground="#334155" FontSize="11" FontWeight="Bold"/>
                                    <TextBox x:Name="txtDescription" Height="28" VerticalContentAlignment="Center"/>
                                </StackPanel>

                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Default Discount (%)" Foreground="#059669" FontSize="11" FontWeight="Bold"/>
                                    <TextBox x:Name="txtCatDiscount" Height="28" Text="0" VerticalContentAlignment="Center"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- Action Buttons -->
                        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,0,12">
                            <Button Content="✨ Clear Form" Background="#64748B" Foreground="White" Width="105" Height="32" Margin="0,0,8,0" Click="BtnClear_Click" Cursor="Hand"/>
                            <Button Content="➕ Add Category" Background="#0D9488" Foreground="White" FontWeight="Bold" Width="135" Height="32" Margin="0,0,8,0" Click="BtnAdd_Click" Cursor="Hand"/>
                            <Button Content="✏️ Edit Selected" Background="#0284C7" Foreground="White" FontWeight="Bold" Width="125" Height="32" Margin="0,0,8,0" Click="BtnEdit_Click" Cursor="Hand"/>
                            <Button Content="🗑️ Delete Category" Background="#EF4444" Foreground="White" FontWeight="Bold" Width="135" Height="32" Click="BtnDelete_Click" Cursor="Hand"/>
                        </StackPanel>

                        <!-- DataGrid -->
                        <DataGrid x:Name="dgCategories" Grid.Row="3" AutoGenerateColumns="False" IsReadOnly="True" SelectionMode="Single" SelectionChanged="DgCategories_SelectionChanged" GridLinesVisibility="Horizontal" HeadersVisibility="Column">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Code" Binding="{Binding CatCode}" Width="65"/>
                                <DataGridTextColumn Header="Category Name" Binding="{Binding CatName}" Width="1.5*"/>
                                <DataGridTextColumn Header="Description" Binding="{Binding Description}" Width="2*"/>
                                <DataGridTextColumn Header="Items Count" Binding="{Binding ItemCount}" FontWeight="Bold" Width="95"/>
                                <DataGridTextColumn Header="Default Discount %" Binding="{Binding CategoryDiscountPercentage, StringFormat='{}{0}%'}" Foreground="#059669" FontWeight="SemiBold" Width="135"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </TabItem>

                <!-- TAB 2: SUB-CATEGORIES -->
                <TabItem Header="📂 Sub-Categories" FontSize="14" FontWeight="Bold">
                    <Grid Margin="0,15,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Header & Search -->
                        <DockPanel Grid.Row="0" Margin="0,0,0,15">
                            <TextBlock Text="Sub-Categories Management" FontSize="16" FontWeight="Bold" Foreground="#0F172A"/>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <TextBlock Text="🔍 Filter Sub-Categories:" VerticalAlignment="Center" Margin="0,0,8,0" Foreground="#64748B" FontSize="12"/>
                                <TextBox x:Name="txtSearchSubCategory" Width="200" Height="28" VerticalContentAlignment="Center" TextChanged="TxtSearchSubCategory_TextChanged"/>
                            </StackPanel>
                        </DockPanel>

                        <!-- Sub Category Inputs -->
                        <Border Grid.Row="1" Background="#F8FAFC" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="6" Padding="12" Margin="0,0,0,12">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="1.5*"/>
                                    <ColumnDefinition Width="1.5*"/>
                                    <ColumnDefinition Width="2*"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0" Margin="0,0,12,0">
                                    <TextBlock Text="Parent Category" Foreground="#334155" FontSize="11" FontWeight="Bold"/>
                                    <ComboBox x:Name="cmbParentCategory" Height="28" DisplayMemberPath="CatName" SelectedValuePath="CatCode"/>
                                </StackPanel>

                                <StackPanel Grid.Column="1" Margin="0,0,12,0">
                                    <TextBlock Text="Sub-Category Name" Foreground="#334155" FontSize="11" FontWeight="Bold"/>
                                    <TextBox x:Name="txtSubCatName" Height="28" VerticalContentAlignment="Center"/>
                                </StackPanel>

                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Description / Notes" Foreground="#334155" FontSize="11" FontWeight="Bold"/>
                                    <TextBox x:Name="txtSubCatDescription" Height="28" VerticalContentAlignment="Center"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- Sub-Category Action Buttons -->
                        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,0,12">
                            <Button Content="✨ Clear Form" Background="#64748B" Foreground="White" Width="105" Height="32" Margin="0,0,8,0" Click="BtnClearSubCat_Click" Cursor="Hand"/>
                            <Button Content="➕ Add Sub-Category" Background="#0D9488" Foreground="White" FontWeight="Bold" Width="155" Height="32" Margin="0,0,8,0" Click="BtnAddSubCat_Click" Cursor="Hand"/>
                            <Button Content="✏️ Edit Selected" Background="#0284C7" Foreground="White" FontWeight="Bold" Width="125" Height="32" Margin="0,0,8,0" Click="BtnEditSubCat_Click" Cursor="Hand"/>
                            <Button Content="🗑️ Delete Sub-Category" Background="#EF4444" Foreground="White" FontWeight="Bold" Width="155" Height="32" Click="BtnDeleteSubCat_Click" Cursor="Hand"/>
                        </StackPanel>

                        <!-- Sub-Category DataGrid -->
                        <DataGrid x:Name="dgSubCategories" Grid.Row="3" AutoGenerateColumns="False" IsReadOnly="True" SelectionMode="Single" SelectionChanged="DgSubCategories_SelectionChanged" GridLinesVisibility="Horizontal" HeadersVisibility="Column">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Code" Binding="{Binding SubCatCode}" Width="65"/>
                                <DataGridTextColumn Header="Sub-Category Name" Binding="{Binding SubCatName}" Width="1.5*"/>
                                <DataGridTextColumn Header="Parent Category" Binding="{Binding CategoryName}" Foreground="#0D9488" FontWeight="Bold" Width="1.5*"/>
                                <DataGridTextColumn Header="Description" Binding="{Binding Description}" Width="2*"/>
                                <DataGridTextColumn Header="Items Count" Binding="{Binding ItemCount}" FontWeight="Bold" Width="95"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </TabItem>
            </TabControl>
        </Border>
    </Grid>
</Page>