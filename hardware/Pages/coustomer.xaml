<!-- CustomerPage.xaml -->
<Page x:Class="HardwareShop.Pages.CustomerPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="CustomerPage">
    
    <Grid Margin="20">
        <StackPanel>
            <TextBlock Text="Customer Debt Management" FontSize="18" Foreground="#E6005C" Margin="0,0,0,20"/>

            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                <TextBox x:Name="txtName" Width="150" Margin="0,0,10,0" />
                <TextBox x:Name="txtPhone" Width="150" Margin="0,0,10,0" />
                <TextBox x:Name="txtDiscount" Width="80" Margin="0,0,10,0" ToolTip="Loyalty Discount %"/>
                <TextBox x:Name="txtCreditLimit" Width="100" Margin="0,0,10,0" ToolTip="Max Credit Limit"/>

                <Button Content="Add Customer" Background="#008F8F" Foreground="White" Width="100" Click="BtnAddCustomer_Click"/>
            </StackPanel>

            <DataGrid x:Name="dgCustomers" AutoGenerateColumns="False" Height="250">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="ID" Binding="{Binding CustomerId}"/>
                    <DataGridTextColumn Header="Name" Binding="{Binding Name}"/>
                    <DataGridTextColumn Header="Phone" Binding="{Binding Phone}"/>
                    <DataGridTextColumn Header="Discount %" Binding="{Binding CustomerLoyaltyDiscount}"/>
                    <DataGridTextColumn Header="Credit Limit" Binding="{Binding CreditLimit}"/>
                    <DataGridTextColumn Header="Current Debt" Binding="{Binding CurrentDebt}" Foreground="Red" FontWeight="Bold"/>
                </DataGrid.Columns>
            </DataGrid>

            <!-- Debt Payment Interface -->
            <StackPanel Orientation="Horizontal" Margin="0,20,0,0">
                <TextBlock Text="Pay Debt Amount: $" VerticalAlignment="Center" Margin="0,0,10,0"/>
                <TextBox x:Name="txtPaymentAmount" Width="100" Height="25" Margin="0,0,10,0"/>
                <Button Content="Settle Debt" Background="#E6005C" Foreground="White" Width="100" Height="30" Click="BtnSettleDebt_Click"/>
            </StackPanel>
        </StackPanel>
    </Grid>
</Page>