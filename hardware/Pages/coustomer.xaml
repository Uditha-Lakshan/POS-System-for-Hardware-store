<Page x:Class="HardwareShop.Pages.CustomerPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="CustomerPage" Loaded="Page_Loaded">

    <Grid Margin="15">
        <Border Background="White" CornerRadius="8" Padding="20">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="1.2*"/>
                    <RowDefinition Height="1*"/>
                </Grid.RowDefinitions>

                <!-- Header & Search -->
                <DockPanel Grid.Row="0" Margin="0,0,0,12">
                    <TextBlock Text="👥 Customer Accounts, Credit &amp; Debt Management" FontSize="18" FontWeight="Bold" Foreground="#0F172A"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <TextBlock Text="🔍 Search Customer:" VerticalAlignment="Center" Margin="0,0,8,0" Foreground="#64748B"/>
                        <TextBox x:Name="txtSearchCustomer" Width="220" Height="30" VerticalContentAlignment="Center" TextChanged="TxtSearchCustomer_TextChanged"/>
                    </StackPanel>
                </DockPanel>

                <!-- Customer Input Form -->
                <Border Grid.Row="1" Background="#F8FAFC" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="6" Padding="12" Margin="0,0,0,12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1.5*"/>
                            <ColumnDefinition Width="1.2*"/>
                            <ColumnDefinition Width="1*"/>
                            <ColumnDefinition Width="1*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Margin="0,0,10,0">
                            <TextBlock Text="Customer Name" Foreground="#334155" FontSize="11" FontWeight="Bold"/>
                            <TextBox x:Name="txtName" Height="30" VerticalContentAlignment="Center"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Margin="0,0,10,0">
                            <TextBlock Text="Phone Number" Foreground="#334155" FontSize="11" FontWeight="Bold"/>
                            <TextBox x:Name="txtPhone" Height="30" VerticalContentAlignment="Center"/>
                        </StackPanel>

                        <StackPanel Grid.Column="2" Margin="0,0,10,0">
                            <TextBlock Text="Loyalty Disc (%)" Foreground="#059669" FontSize="11" FontWeight="Bold"/>
                            <TextBox x:Name="txtDiscount" Height="30" Text="0" VerticalContentAlignment="Center"/>
                        </StackPanel>

                        <StackPanel Grid.Column="3">
                            <TextBlock Text="Credit Limit (Rs.)" Foreground="#334155" FontSize="11" FontWeight="Bold"/>
                            <TextBox x:Name="txtCreditLimit" Height="30" Text="500" VerticalContentAlignment="Center"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Customer Action Buttons -->
                <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,0,12">
                    <Button Content="✨ Clear Form" Background="#64748B" Foreground="White" Width="105" Height="32" Margin="0,0,10,0" Click="BtnClearCustomer_Click" Cursor="Hand"/>
                    <Button Content="➕ Add Customer" Background="#0D9488" Foreground="White" FontWeight="Bold" Width="130" Height="32" Margin="0,0,10,0" Click="BtnAddCustomer_Click" Cursor="Hand"/>
                    <Button Content="✏️ Edit Selected" Background="#0284C7" Foreground="White" FontWeight="Bold" Width="130" Height="32" Margin="0,0,10,0" Click="BtnEditCustomer_Click" Cursor="Hand"/>
                    <Button Content="🗑️ Delete Customer" Background="#EF4444" Foreground="White" FontWeight="Bold" Width="135" Height="32" Click="BtnDeleteCustomer_Click" Cursor="Hand"/>
                </StackPanel>

                <!-- Customers DataGrid -->
                <DataGrid x:Name="dgCustomers" Grid.Row="3" AutoGenerateColumns="False" IsReadOnly="True" SelectionMode="Single" SelectionChanged="DgCustomers_SelectionChanged" GridLinesVisibility="Horizontal" HeadersVisibility="Column" Margin="0,0,0,12">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="45"/>
                        <DataGridTextColumn Header="Customer Name" Binding="{Binding Name}" Width="1.8*"/>
                        <DataGridTextColumn Header="Phone" Binding="{Binding Phone}" Width="1.2*"/>
                        <DataGridTextColumn Header="Loyalty %" Binding="{Binding CustomerLoyaltyDiscount, StringFormat='{}{0}%'}" Foreground="#059669" FontWeight="SemiBold" Width="75"/>
                        <DataGridTextColumn Header="Credit Limit" Binding="{Binding CreditLimit, StringFormat='Rs. {0:F2}'}" Width="110"/>
                        <DataGridTextColumn Header="Current Debt" Binding="{Binding CurrentDebt, StringFormat='Rs. {0:F2}'}" Foreground="#DC2626" FontWeight="Bold" Width="115"/>
                        <DataGridTextColumn Header="Avail. Credit" Binding="{Binding AvailableCredit, StringFormat='Rs. {0:F2}'}" Foreground="#059669" FontWeight="Bold" Width="115"/>
                        <DataGridTextColumn Header="Status" Binding="{Binding DebtStatus}" FontWeight="SemiBold" Width="85"/>
                    </DataGrid.Columns>
                </DataGrid>

                <!-- LOWER PANEL: DEBT SETTLEMENT & PAYMENT LEDGER -->
                <Grid Grid.Row="4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="4.2*"/>
                        <ColumnDefinition Width="5.8*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Left: Debt Settlement Controls -->
                    <Border Grid.Column="0" Background="#F0FDF4" BorderBrush="#BBF7D0" BorderThickness="1" CornerRadius="6" Padding="12" Margin="0,0,8,0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Text="💳 Settle Debt Account" FontWeight="Bold" Foreground="#065F46" FontSize="14" Margin="0,0,0,8"/>

                            <Grid Grid.Row="1" Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="1*"/>
                                    <ColumnDefinition Width="1*"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0" Margin="0,0,5,0">
                                    <TextBlock Text="Payment Amount (Rs.)" FontSize="11" Foreground="#334155" FontWeight="Bold"/>
                                    <TextBox x:Name="txtPaymentAmount" Height="30" VerticalContentAlignment="Center"/>
                                </StackPanel>

                                <StackPanel Grid.Column="1" Margin="5,0,0,0">
                                    <TextBlock Text="Payment Method" FontSize="11" Foreground="#334155" FontWeight="Bold"/>
                                    <ComboBox x:Name="cmbPaymentMethod" Height="30" SelectedIndex="0">
                                        <ComboBoxItem Content="Cash"/>
                                        <ComboBoxItem Content="Card"/>
                                        <ComboBoxItem Content="Bank Transfer"/>
                                        <ComboBoxItem Content="Cheque"/>
                                    </ComboBox>
                                </StackPanel>
                            </Grid>

                            <StackPanel Grid.Row="2" Margin="0,0,0,8">
                                <TextBlock Text="Reference / Payment Note" FontSize="11" Foreground="#334155" FontWeight="Bold"/>
                                <TextBox x:Name="txtPaymentNotes" Height="30" VerticalContentAlignment="Center"/>
                            </StackPanel>

                            <UniformGrid Grid.Row="3" Columns="3">
                                <Button Content="💵 Pay Debt" Background="#0D9488" Foreground="White" FontWeight="Bold" Height="34" Margin="0,0,4,0" Click="BtnSettleDebt_Click" Cursor="Hand"/>
                                <Button Content="⚡ Pay Full Debt" Background="#059669" Foreground="White" FontWeight="Bold" Height="34" Margin="2,0,2,0" Click="BtnSettleFullDebt_Click" Cursor="Hand"/>
                                <Button Content="🖨️ Statement" Background="#0284C7" Foreground="White" FontWeight="Bold" Height="34" Margin="4,0,0,0" Click="BtnPrintStatement_Click" Cursor="Hand"/>
                            </UniformGrid>
                        </Grid>
                    </Border>

                    <!-- Right: Customer Debt Payment Ledger -->
                    <Border Grid.Column="1" Background="#F8FAFC" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="6" Padding="10" Margin="8,0,0,0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" x:Name="lblLedgerHeader" Text="📜 Debt Payment History Log" FontWeight="Bold" Foreground="#334155" FontSize="13" Margin="0,0,0,6"/>

                            <DataGrid x:Name="dgPaymentHistory" Grid.Row="1" AutoGenerateColumns="False" IsReadOnly="True" GridLinesVisibility="Horizontal" HeadersVisibility="Column">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Date" Binding="{Binding PaymentDate, StringFormat='yyyy-MM-dd HH:mm'}" Width="120"/>
                                    <DataGridTextColumn Header="Paid (Rs.)" Binding="{Binding AmountPaid, StringFormat='Rs. {0:F2}'}" Foreground="#059669" FontWeight="Bold" Width="100"/>
                                    <DataGridTextColumn Header="Rem. Debt" Binding="{Binding RemainingDebt, StringFormat='Rs. {0:F2}'}" Foreground="#DC2626" FontWeight="Bold" Width="100"/>
                                    <DataGridTextColumn Header="Method" Binding="{Binding PaymentMethod}" Width="85"/>
                                    <DataGridTextColumn Header="Notes" Binding="{Binding Notes}" Width="*"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Page>