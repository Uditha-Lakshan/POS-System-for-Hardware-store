<Window x:Class="HardwareShop.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Login to HardwareShop" Height="450" Width="400" WindowStartupLocation="CenterScreen" Background="#222222">
    <Grid Margin="30">
        <StackPanel VerticalAlignment="Center">
            <TextBlock Text="Hardware POS" FontSize="28" FontWeight="Bold" Foreground="#008F8F" HorizontalAlignment="Center" Margin="0,0,0,5"/>
            <TextBlock Text="Please Login or Register" FontSize="14" Foreground="Gray" HorizontalAlignment="Center" Margin="0,0,0,30"/>

            <TextBlock Text="Username" Foreground="White" Margin="0,0,0,5"/>
            <TextBox x:Name="txtUsername" Height="30" Margin="0,0,0,15" Padding="5"/>

            <TextBlock Text="Password" Foreground="White" Margin="0,0,0,5"/>
            <PasswordBox x:Name="txtPassword" Height="30" Margin="0,0,0,25" Padding="5"/>

            <Button Content="LOGIN" Background="#008F8F" Foreground="White" Height="40" FontWeight="Bold" Margin="0,0,0,10" Click="BtnLogin_Click"/>
            <Button Content="REGISTER NEW USER" Background="Transparent" Foreground="#E6005C" BorderBrush="#E6005C" Height="40" FontWeight="Bold" Click="BtnRegister_Click"/>
        </StackPanel>
    </Grid>
</Window>