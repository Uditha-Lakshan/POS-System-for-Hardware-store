<Window x:Class="HardwareShop.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Login - Nimal Hardware Store POS" Height="517" Width="440" WindowStartupLocation="CenterScreen" Background="#0F172A" ResizeMode="NoResize">
    <Grid>
        <!-- Background Accent Glow -->
        <Border Margin="20" Background="#1E293B" CornerRadius="12" Padding="30" BorderBrush="#334155" BorderThickness="1">
            <StackPanel VerticalAlignment="Center">
                <!-- Shop Header & Logo Badge -->
                <Border Width="60" Height="60" Background="#0D9488" CornerRadius="30" HorizontalAlignment="Center" Margin="0,0,0,15">
                    <TextBlock Text="🛠️" FontSize="28" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <TextBlock Text="Nimal Hardware Store" FontSize="22" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center" Margin="0,0,0,4"/>
                <TextBlock Text="Store Management System v2.0" FontSize="12" Foreground="#94A3B8" HorizontalAlignment="Center" Margin="0,0,0,25"/>

                <!-- Username Input -->
                <TextBlock Text="Username" Foreground="#CBD5E1" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,5"/>
                <TextBox x:Name="txtUsername" Height="36" Margin="0,0,0,15" Background="#0F172A" Foreground="White" BorderBrush="#475569" Padding="10,0" VerticalContentAlignment="Center"/>

                <!-- Password Input -->
                <TextBlock Text="Password" Foreground="#CBD5E1" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,5"/>
                <PasswordBox x:Name="txtPassword" Height="36" Margin="0,0,0,25" Background="#0F172A" Foreground="White" BorderBrush="#475569" Padding="10,0" VerticalContentAlignment="Center"/>

                <!-- Action Buttons -->
                <Button Content="🔒 LOGIN TO SYSTEM" Background="#0D9488" Foreground="White" Height="42" FontSize="14" FontWeight="Bold" Margin="0,0,0,10" Click="BtnLogin_Click" Cursor="Hand"/>
                <Button Content="➕ REGISTER NEW USER" Background="Transparent" Foreground="#F59E0B" BorderBrush="#F59E0B" BorderThickness="1" Height="38" FontSize="13" FontWeight="SemiBold" Click="BtnRegister_Click" Cursor="Hand"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>